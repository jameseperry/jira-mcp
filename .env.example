# Default Jira Cloud base URL (e.g. https://mycompany.atlassian.net)
JIRA_BASE_URL=
# Email associated with your Atlassian account
JIRA_EMAIL=
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Additional Jira instances (optional)
# Use JIRA_BASE_URL_<name> for each extra instance.
# Tools accept an optional "instance" parameter to target these.
# JIRA_BASE_URL_amd=https://amd.atlassian.net
